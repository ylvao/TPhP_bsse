# vim:syntax=sh:

world_prec = 1.0e-06
world_unit = angstrom

MPI {
  omp_threads = 32
  bank_size   = 16        # 2 x antall noder
  numerically_exact       = false
  share_nuclear_potential = true
  share_coulomb_potential = true
}

Basis {
  order = 7
}

WaveFunction {
  method = DFT
  restricted = true
}

DFT {
$functionals
bp86
$end
  xc_library = libxc
}

SCF {
  kain = 4
  localize = true
  run = true
  guess_type = gto
  guess_prec = 1.0e-06
  start_prec = 1.0e-06
  final_prec = 1.0e-06
  orbital_thrs = 1.0e-03
  energy_thrs = 1.0e-04
}

